# ── Banco de dados (Supabase PostgreSQL) ─────────────────────────────
# Pooled connection (para runtime da aplicação)
DATABASE_URL="postgresql://postgres:[PASSWORD]@[PROJECT].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (usada por `prisma migrate`)
DIRECT_URL="postgresql://postgres:[PASSWORD]@[PROJECT].supabase.co:5432/postgres"

# ── NextAuth ──────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-com: openssl rand -base64 32"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Cloudinary (upload de imagens, PDFs, áudios) ─────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Stripe (pagamentos) ───────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_BUSINESS=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ── Resend (e-mails transacionais) ───────────────────────────────────
RESEND_API_KEY=""
