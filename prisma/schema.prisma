// Vault — Schema Prisma
// Banco: PostgreSQL via Supabase

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id                 String   @id @default(cuid())
  name               String?
  email              String   @unique
  emailVerified      DateTime?
  image              String?
  passwordHash       String?

  // Cofre de senhas — hash da senha mestra + salt de derivação (NUNCA a chave em si)
  vaultMasterKeyHash String?
  vaultSalt          String?

  plan               String   @default("free")
  storageUsed        BigInt   @default(0)
  storageLimit       BigInt   @default(524288000) // 500MB no plano free

  items              Item[]
  folders            Folder[]
  accounts           Account[]
  sessions           Session[]

  stripeCustomerId       String?  @unique
  stripeSubscriptionId   String?  @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([email])
}

model Folder {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?
  color       String   @default("violet") // violet | purple | rose | amber | emerald | sky
  icon        String   @default("folder")

  parentId    String?
  parent      Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Folder[] @relation("FolderHierarchy")

  items       Item[]

  order       Int      @default(0)
  isRoot      Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, parentId])
}

model Item {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  folderId String?
  folder   Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  type        String // IMAGE | PDF | AUDIO | NOTE | SNIPPET | LINK | PASSWORD
  title       String
  description String?
  tags        String[]
  color       String?  @default("violet")

  isFavorite Boolean   @default(false)
  isArchived Boolean   @default(false)
  isDeleted  Boolean   @default(false)
  deletedAt  DateTime?

  order Int @default(0)

  // Arquivos (Cloudinary): imagem, pdf, áudio
  url      String?
  fileKey  String?
  fileSize BigInt?
  mimeType String?

  // Snippet
  codeLanguage String?
  codeContent  String?

  // Nota / bloco markdown
  noteContent String?

  // Link com preview OG
  linkOgTitle       String?
  linkOgDescription String?
  linkOgImage       String?
  linkFavicon       String?

  // Senha (criptografada — AES-256-GCM)
  encryptedUsername String?
  encryptedPassword String?
  encryptedNotes    String?
  passwordStrength  String? // weak | medium | strong

  // IA (busca semântica futura)
  embedding Unsupported("vector(1536)")?
  aiTags    String[] @default([])
  aiSummary String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, folderId])
  @@index([userId, type])
  @@index([userId, isDeleted])
  @@index([userId, isFavorite])
  @@index([userId, isArchived])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
